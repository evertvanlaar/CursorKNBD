        "jsCode": "const j = $input.first().json;\nconst fileContent = String(j.jsonText ?? '');\nif (!fileContent) throw new Error('Pack JSON: jsonText ontbreekt of is leeg');\nconst fileName = 'data/bus-schedule.json';\nreturn [{ json: { fileName, fileContent, byteSize: Buffer.byteLength(fileContent, 'utf8'), generatedAt: j.envelope?.generatedAt ?? null, rowCount: j.envelope?.rowCount ?? null, stagingFileName: j.stagingFileName ?? 'bus-schedule.staging.json' } }];"
      },
