## Copy to keystore.properties (do NOT commit that file).
## Use the same keystore you use for Play uploads.
##
## Example:
## storeFile=C:\\path\\to\\signing.keystore
## storePassword=YOUR_STORE_PASSWORD
## keyAlias=my-key-alias
## keyPassword=YOUR_KEY_PASSWORD

storeFile=C:\\path\\to\\signing.keystore
storePassword=
keyAlias=my-key-alias
keyPassword=
